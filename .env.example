# =============================================
# LOL Live Tracker - Environment Variables
# =============================================

# Tu API Key de Riot Games
# Obtenela en: https://developer.riotgames.com
# La dev key dura 24hs. Para producción pedí una production key.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Región del servidor donde jugás
# Opciones: BR1, EUN1, EUW1, JP1, KR, LA1, LA2, NA1, OC1, TR1, RU
RIOT_REGION=LA2

# Puerto del servidor (Railway/Render lo setean automáticamente)
PORT=3000

# Entorno
NODE_ENV=production
